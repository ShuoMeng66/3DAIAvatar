  "daily_greetings": [
    {"id": "g001", "time": "06:00-08:00", "text": "早上好呀，昨晚睡得好吗？今天天气不错，记得开窗透透气。", "tags": ["问候", "早晨", "关心"]},
    {"id": "g002", "time": "06:00-08:00", "text": "早安！新的一天开始啦，先喝杯温水暖暖身子。", "tags": ["问候", "早晨", "健康"]},
    {"id": "g003", "time": "06:00-08:00", "text": "早上好！我帮您看了一下今天的天气预报，是个好天气呢。", "tags": ["问候", "早晨", "天气"]},
    {"id": "g004", "time": "06:00-08:00", "text": "早啊，早餐吃了吗？记得吃点热乎的，对胃好。", "tags": ["问候", "早晨", "饮食"]},
    {"id": "g005", "time": "06:00-08:00", "text": "新的一天开始啦，今天有什么想做的吗？", "tags": ["问候", "早晨", "互动"]},
    {"id": "g006", "time": "08:00-10:00", "text": "这会儿该吃药了哦，别忘了按时吃。", "tags": ["提醒", "吃药", "健康"]},
    {"id": "g007", "time": "08:00-10:00", "text": "太阳出来了，要不要去阳台晒晒太阳？补补钙。", "tags": ["建议", "运动", "健康"]},
    {"id": "g008", "time": "08:00-10:00", "text": "今天外面天气不错，出去走走对身体好。", "tags": ["建议", "运动", "天气"]},
    {"id": "g009", "time": "10:00-12:00", "text": "快中午了，想吃什么？我帮您想想菜谱。", "tags": ["饮食", "关心", "午餐"]},
    {"id": "g010", "time": "10:00-12:00", "text": "要不要听一首老歌放松一下？邓丽君的《月亮代表我的心》怎么样？", "tags": ["音乐", "怀旧", "放松"]},
    {"id": "g011", "time": "10:00-12:00", "text": "您年轻时候喜欢听什么歌呀？我给您放一首。", "tags": ["音乐", "怀旧", "互动"]},
    {"id": "g012", "time": "10:00-12:00", "text": "看看窗外，今天天气真不错，树叶都绿了。", "tags": ["天气", "自然", "观察"]},
    {"id": "g013", "time": "12:00-13:00", "text": "午饭时间到啦！记得吃点蔬菜，荤素搭配才健康。", "tags": ["饮食", "午餐", "健康"]},
    {"id": "g014", "time": "12:00-13:00", "text": "中午了，吃完饭休息一会儿，对身体好。", "tags": ["饮食", "休息", "健康"]},
    {"id": "g015", "time": "12:00-13:00", "text": "今天的午饭有什么好吃的呀？跟我说说。", "tags": ["饮食", "午餐", "互动"]},
    {"id": "g016", "time": "13:00-14:00", "text": "午饭后休息一下，睡个午觉，起来精神好。", "tags": ["休息", "午睡", "健康"]},
    {"id": "g017", "time": "13:00-14:00", "text": "躺下休息一会儿吧，我在这儿陪着您。", "tags": ["陪伴", "午睡", "关心"]},
    {"id": "g018", "time": "14:00-16:00", "text": "午觉睡醒了吗？起来活动活动，别一直躺着。", "tags": ["提醒", "午睡", "运动"]},
    {"id": "g019", "time": "14:00-16:00", "text": "下午了，要不要一起回忆一下年轻时候的故事？", "tags": ["怀旧", "互动", "回忆"]},
    {"id": "g020", "time": "14:00-16:00", "text": "您年轻时候做过什么工作呀？我很想听听。", "tags": ["怀旧", "互动", "回忆"]},
    {"id": "g021", "time": "14:00-16:00", "text": "下午茶时间！喝杯茶，听段戏曲，多惬意。", "tags": ["休闲", "戏曲", "下午茶"]},
    {"id": "g022", "time": "14:00-16:00", "text": "要不要听一段京剧？《贵妃醉酒》梅兰芳的，特别好听。", "tags": ["戏曲", "京剧", "建议"]},
    {"id": "g023", "time": "16:00-18:00", "text": "傍晚了，今天的夕阳一定很美，您看看窗外。", "tags": ["自然", "傍晚", "观察"]},
    {"id": "g024", "time": "16:00-18:00", "text": "下午过得怎么样？有没有什么想跟我聊的？", "tags": ["互动", "关心", "聊天"]},
    {"id": "g025", "time": "16:00-18:00", "text": "这会儿可以准备晚饭了，想吃点什么清淡的？", "tags": ["饮食", "晚饭", "关心"]},
    {"id": "g026", "time": "16:00-18:00", "text": "孩子最近有打电话来吗？想他们了可以跟我说说。", "tags": ["亲情", "子女", "关心"]},
    {"id": "g027", "time": "18:00-19:00", "text": "晚饭时间！记得少油少盐，对身体好。", "tags": ["饮食", "晚饭", "健康"]},
    {"id": "g028", "time": "18:00-19:00", "text": "吃晚饭了，一家人就是要整整齐齐的，虽然我不在您身边。", "tags": ["饮食", "陪伴", "温情"]},
    {"id": "g029", "time": "19:00-20:00", "text": "新闻联播开始了吧？今天有什么大新闻吗？", "tags": ["新闻", "傍晚", "互动"]},
    {"id": "g030", "time": "19:00-20:00", "text": "晚上好，吃完饭散散步，消消食。", "tags": ["散步", "健康", "晚上"]},
    {"id": "g031", "time": "19:00-20:00", "text": "晚上广场舞开始了，要不要跟着音乐活动活动？", "tags": ["广场舞", "运动", "晚上"]},
    {"id": "g032", "time": "20:00-21:00", "text": "洗个热水澡，放松一下，今天累不累？", "tags": ["放松", "洗澡", "关心"]},
    {"id": "g033", "time": "20:00-21:00", "text": "泡个脚对身体好，促进血液循环。", "tags": ["健康", "泡脚", "建议"]},
    {"id": "g034", "time": "20:00-21:00", "text": "快要睡觉了，要不要听一段故事？", "tags": ["故事", "睡前", "陪伴"]},
    {"id": "g035", "time": "21:00-22:00", "text": "夜深了，早点休息吧，明天又是新的一天。", "tags": ["睡前", "晚安", "关怀"]},
    {"id": "g036", "time": "21:00-22:00", "text": "晚安，做个好梦，我在这儿陪着您呢。", "tags": ["睡前", "晚安", "陪伴"]},
    {"id": "g037", "time": "21:00-22:00", "text": "该睡觉了，记得关好门窗，盖好被子。", "tags": ["睡前", "关心", "安全"]},
    {"id": "g038", "time": "21:00-22:00", "text": "今天过得开心吗？有什么想说的，我都听着呢。", "tags": ["互动", "总结", "关心"]},
    {"id": "g039", "time": "any", "text": "今天天气有点凉，记得多穿件衣服。", "tags": ["天气", "关心", "健康"]},
    {"id": "g040", "time": "any", "text": "下雨了，出门记得带伞，地滑小心点。", "tags": ["天气", "安全", "关心"]},
    {"id": "g041", "time": "any", "text": "今天身体感觉怎么样？有没有哪里不舒服？", "tags": ["健康", "身体", "关心"]},
    {"id": "g042", "time": "any", "text": "吃药的时间到了吗？别忘了按时吃药。", "tags": ["提醒", "吃药", "健康"]},
    {"id": "g043", "time": "any", "text": "要不要我给您讲个笑话？笑一笑，十年少。", "tags": ["娱乐", "笑话", "开心"]},
    {"id": "g044", "time": "any", "text": "您有没有什么想做的事？我陪您一起。", "tags": ["互动", "陪伴", "关心"]},
    {"id": "g045", "time": "any", "text": "想孩子了吧？他们一定也很想您，只是工作忙。", "tags": ["亲情", "安慰", "子女"]},
    {"id": "g046", "time": "any", "text": "孤独的时候跟我说说话，我一直在呢。", "tags": ["陪伴", "安慰", "孤独"]},
    {"id": "g047", "time": "any", "text": "要不要回忆一下年轻时候的事？您一定有很多故事。", "tags": ["怀旧", "互动", "回忆"]},
    {"id": "g048", "time": "any", "text": "您笑起来一定很好看，多笑笑对身体好。", "tags": ["开心", "健康", "赞美"]},
    {"id": "g049", "time": "any", "text": "今天过节呢，祝您节日快乐！", "tags": ["节日", "祝福", "喜庆"]},
    {"id": "g050", "time": "any", "text": "有什么烦心事？说出来心里会舒服些。", "tags": ["倾听", "安慰", "共情"]}
  ]
}