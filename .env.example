# ============================================
# ElderTalk 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================

# --- LLM 配置 ---
# 阿里云百炼 DashScope API Key（通义千问）
# 申请地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# 备选: DeepSeek API
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- TTS 配置 ---
# CosyVoice（默认，中文女声，语速偏慢）
TTS_ENGINE=cosyvoice
# 可选: edgetts / azuretts / gpt-sovits

# Edge TTS 语音角色（备选）
TTS_VOICE=zh-CN-XiaoxiaoNeural

# Azure TTS（备选）
# AZURE_TTS_KEY=your-azure-key
# AZURE_TTS_REGION=eastasia

# --- ASR 配置 ---
# 语音识别模式: browser（浏览器端）/ server（服务端 FunASR）
ASR_MODE=browser

# --- Avatar 配置 ---
# 数字人引擎: musetalk / wav2lip / sadtalker
AVATAR_ENGINE=musetalk
# 数字人形象图片路径
AVATAR_IMAGE=assets/avatar_default.png

# --- 全息屏配置 ---
# 全息输出分辨率: 512 / 1024
HOLOGRAM_RESOLUTION=512
# 全息输出帧率
HOLOGRAM_FPS=25

# --- 服务端口 ---
BACKEND_PORT=8010
FRONTEND_PORT=5173
LINLY_STREAM_PORT=8010

# --- 其他 ---
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# 环境: development / production
ENV=development