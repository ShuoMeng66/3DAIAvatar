# ElderTalk / 颐语 — 环境变量
# 复制为 .env 并填写

# LLM（百炼 DashScope 或 DeepSeek）
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Linly-Talker-Stream（与 backend 同机时用 localhost）
LINLY_STREAM_URL=http://127.0.0.1:8000

# 服务
PORT=8010
FRONTEND_ORIGIN=http://localhost:5173

# TTS 降级（Linly 不可用时）
TTS_ENGINE=edge-tts
TTS_VOICE=zh-CN-XiaoxiaoNeural

# 数字人
AVATAR_ENGINE=musetalk
AVATAR_DEFAULT=yiyu

LOG_LEVEL=INFO

# 前端 Vite 变量请配置 frontend/.env（见 frontend/.env.example）
