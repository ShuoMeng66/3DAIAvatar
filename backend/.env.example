# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8010
FRONTEND_ORIGIN=http://localhost:5173

# ==================== LLM 配置 ====================
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ==================== TTS 配置 ====================
# 可选：edge-tts / openai-tts / volcengine-tts
TTS_ENGINE=edge-tts
TTS_VOICE=zh-CN-XiaoxiaoNeural

# ==================== ASR 配置 ====================
# 可选：whisper / volcengine-asr
ASR_MODE=whisper
WHISPER_MODEL=base

# ==================== 全息/数字人配置 ====================
# 可选：placeholder / volcengine
AVATAR_ENGINE=placeholder
AVATAR_DEFAULT=xiaonuan

# ==================== 日志配置 ====================
LOG_LEVEL=info